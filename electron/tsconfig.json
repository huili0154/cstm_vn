{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "composite": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"]
}

